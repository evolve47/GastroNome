---
import Navbar from '@components/ui/Navbar.astro';
import Footer from '@components/ui/Footer.astro';
import { siteConfig } from '@data/site';
import { getHreflangUrls, t } from '../i18n/utils';
import type { Locale } from '../i18n/ui';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  structuredData?: object;
  noindex?: boolean;
  lang?: Locale;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  ogImage = '/images/restaurant-floor-1.webp',
  canonical,
  structuredData,
  noindex = false,
  lang = 'sv',
} = Astro.props;

const pageTitle = title === siteConfig.name
  ? title
  : `${title} | ${siteConfig.name}`;

const canonicalUrl = canonical
  ? new URL(canonical, siteConfig.url).href
  : new URL(Astro.url.pathname, siteConfig.url).href;

const defaultOgImage = '/images/restaurant-floor-1.webp';
const ogImageUrl = ogImage?.startsWith('http')
  ? ogImage
  : new URL(ogImage ?? defaultOgImage, siteConfig.url).href;

const ogLocale = lang === 'en' ? 'en_GB' : 'sv_SE';

const hreflangUrls = getHreflangUrls(Astro.url.pathname, lang, siteConfig.url);

/* ── JSON-LD: LocalBusiness + Restaurant ── */
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Gastronome',
  description: siteConfig.description,
  url: siteConfig.url,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  image: new URL('/images/restaurant-floor-1.webp', siteConfig.url).href,
  logo: new URL('/images/gastronome-1.png', siteConfig.url).href,
  priceRange: '$$',
  servesCuisine: ['Italian', 'Swedish'],
  award: siteConfig.stats.awards.join(', '),
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.address.street,
    postalCode: siteConfig.address.zip,
    addressLocality: siteConfig.address.city,
    addressCountry: 'SE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 55.7047,
    longitude: 13.1910,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: parseFloat(siteConfig.stats.rating),
    reviewCount: parseInt(siteConfig.stats.totalReviews, 10),
    bestRating: 5,
    worstRating: 1,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Tuesday',
      opens: '17:00',
      closes: '22:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Wednesday',
      opens: '17:00',
      closes: '23:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Thursday',
      opens: '17:00',
      closes: '23:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Friday',
      opens: '15:00',
      closes: '00:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '15:00',
      closes: '00:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Sunday',
      opens: '15:00',
      closes: '22:00',
    },
  ],
};
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Preload hero poster image for LCP -->
    <link rel="preload" as="image" href="/images/2026-02-20 (1).webp" type="image/webp" />

    <!-- DNS prefetch for third-party services -->
    <link rel="dns-prefetch" href="https://formsubmit.co" />
    <link rel="dns-prefetch" href="https://eatsmart.se" />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF9" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang tags for SEO -->
    {hreflangUrls.map(({ lang: hLang, href }) => (
      <link rel="alternate" hreflang={hLang} href={href} />
    ))}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/gastronome-1.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Gastronome" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD: Restaurant Schema -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- Additional structured data from page -->
    {structuredData && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}

    <!-- Remove no-js class -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Hoppa till innehåll</a>
    <Navbar lang={lang} />

    <main id="main-content">
      <slot />
    </main>

    <Footer lang={lang} />

    <!-- Scroll-to-top button -->
    <button
      id="scroll-top"
      class="scroll-top-btn"
      aria-label={t(lang, 'ui.scrollToTop')}
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path
          d="M10 16V4M10 4L4 10M10 4L16 10"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>

    <!-- Global: Intersection Observer for scroll-reveal animations -->
    <script is:inline>
      (function () {
        var selectors = '.reveal, .fade-up, .fade-in, .slide-in-left, .slide-in-right';
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function observe() {
          var els = document.querySelectorAll(selectors);
          if (reducedMotion) {
            els.forEach(function(el) { el.classList.add('is-visible'); });
            return;
          }
          var observer = new IntersectionObserver(
            function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
          );
          els.forEach(function(el) { observer.observe(el); });
        }

        observe();
        document.addEventListener('astro:page-load', observe);
        document.addEventListener('astro:after-swap', observe);
      })();
    </script>

    <!-- Scroll-to-top logic -->
    <script is:inline>
      (function () {
        const btn = document.getElementById('scroll-top');
        if (!btn) return;

        function toggle() {
          if (window.scrollY > 600) {
            btn.classList.add('visible');
          } else {
            btn.classList.remove('visible');
          }
        }

        window.addEventListener('scroll', toggle, { passive: true });
        toggle();

        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
  </body>
</html>

<style>
  /* Skip-to-main link */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.5rem;
    background: #1A1A1A;
    color: #fff;
    border-radius: 0 0 0.5rem 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 0;
  }

  /* Scroll-to-top button */
  .scroll-top-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: var(--z-above, 10);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--glass-bg, rgba(255, 255, 255, 0.72));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border-subtle, #e8e5e0);
    color: var(--color-text-primary, #1a1a1a);
    box-shadow: var(--shadow-md, 0 4px 16px rgba(0, 0, 0, 0.08));
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px);
    transition:
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.2s ease;
  }

  .scroll-top-btn.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .scroll-top-btn:hover {
    background: var(--color-accent-warm, #8b6f47);
    color: #fff;
    border-color: var(--color-accent-warm, #8b6f47);
  }

  .scroll-top-btn:active {
    transform: scale(0.93);
  }

  @media (max-width: 767px) {
    .scroll-top-btn {
      bottom: 1.25rem;
      right: 1.25rem;
      width: 42px;
      height: 42px;
    }
  }
</style>
