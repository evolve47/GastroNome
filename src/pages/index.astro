---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import AwardsBanner from '../components/sections/AwardsBanner.astro';
import ConceptIntro from '../components/sections/ConceptIntro.astro';
import FoodShowcase from '../components/sections/FoodShowcase.astro';
import EventHighlights from '../components/sections/EventHighlights.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FoundersStory from '../components/sections/FoundersStory.astro';
import TakeawayDelivery from '../components/sections/TakeawayDelivery.astro';
import InstagramFeed from '../components/sections/InstagramFeed.astro';
---

<BaseLayout
  title="GASTRO|nome — Mat & Bar i Lund | Italiensk-Svensk Fusion"
  description="Upplev GASTRO|nome, Lunds #1 restaurang. Prisbelönt italiensk-svensk fusion, vinnare av Pizza SM 2023 & 2024. Boka bord på Bangatan 6, Lund."
>
  <Hero />
  <AwardsBanner />
  <ConceptIntro />
  <FoodShowcase />
  <EventHighlights />
  <Testimonials />
  <FoundersStory />
  <TakeawayDelivery />
  <InstagramFeed />
</BaseLayout>

<!-- Scroll animation observer is handled globally by BaseLayout -->

