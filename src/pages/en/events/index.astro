---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/ui/Button.astro';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title={t(lang, 'events.metaTitle')}
  description={t(lang, 'events.metaDesc')}
>
  <!-- Hero -->
  <section class="events-hero">
    <div class="events-hero__bg">
      <img src="/images/2026-02-20.webp" alt="Romantic table setting with rose petals and candles at GASTRO|nome" loading="eager" />
      <div class="events-hero__overlay"></div>
    </div>
    <div class="events-hero__content">
      <span class="events-hero__eyebrow">{t(lang, 'events.heroEyebrow')}</span>
      <h1 class="events-hero__title" set:html={t(lang, 'events.heroTitle')} />
      <p class="events-hero__sub">{t(lang, 'events.heroSub')}</p>
    </div>
  </section>

  <!-- Recurring: Bubble Thursday -->
  <section class="event-feature">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/619226756_18080282837349192_8699460402074805794_n.webp" alt="Champagne being poured into glasses" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">{t(lang, 'events.bubbleBadge')}</span>
        <h2 class="event-feature__title">{t(lang, 'events.bubbleTitle')}</h2>
        <p class="event-feature__text">{t(lang, 'events.bubbleText')}</p>
        <p class="event-feature__detail">
          <strong>{t(lang, 'events.bubbleWhen')}</strong> {t(lang, 'events.bubbleWhenVal')}<br />
          <strong>{t(lang, 'events.bubbleOffer')}</strong> {t(lang, 'events.bubbleOfferVal')}
        </p>
        <Button href="/en/book-a-table/" variant="primary">{t(lang, 'events.bubbleCta')}</Button>
      </div>
    </div>
  </section>

  <!-- Pizza SM -->
  <section class="event-feature event-feature--reversed event-feature--dark">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/fc037b4ad21057456dde5a40cd6d09f2-thumb_large.webp" alt="Championship-winning margherita pizza" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">{t(lang, 'events.pizzaBadge')}</span>
        <h2 class="event-feature__title">{t(lang, 'events.pizzaTitle')}</h2>
        <p class="event-feature__text" set:html={t(lang, 'events.pizzaText')} />
        <div class="event-feature__awards">
          <img src="/images/pizza-champion-cup.webp" alt="Pizza SM trophy" width="48" height="48" />
          <div>
            <span>{t(lang, 'events.pizzaAward1')}</span>
            <span>{t(lang, 'events.pizzaAward2')}</span>
          </div>
        </div>
        <Button href="/en/menus/" variant="outline">{t(lang, 'events.pizzaCta')}</Button>
      </div>
    </div>
  </section>

  <!-- Large Groups -->
  <section class="event-feature">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/467249171_18037063073349192_5208946929036331443_n.webp" alt="Large dinner party" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">{t(lang, 'events.groupBadge')}</span>
        <h2 class="event-feature__title">{t(lang, 'events.groupTitle')}</h2>
        <p class="event-feature__text">{t(lang, 'events.groupText')}</p>
        <Button href="/en/large-groups/" variant="primary">{t(lang, 'events.groupCta')}</Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="events-cta">
    <div class="events-cta__inner fade-up">
      <h2 class="events-cta__title">{t(lang, 'events.ctaTitle')}</h2>
      <p class="events-cta__text">{t(lang, 'events.ctaText')}</p>
      <a href="https://www.instagram.com/gastronomelund" target="_blank" rel="noopener noreferrer" class="events-cta__link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
        </svg>
        @gastronomelund
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

<style>
  .events-hero {
    position: relative;
    height: 50vh;
    min-height: 360px;
    max-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }
  .events-hero__bg { position: absolute; inset: 0; }
  .events-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .events-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.2), rgba(0,0,0,0.6)); }
  .events-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .events-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .events-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 400; color: #fff; margin: 0 0 0.75rem; }
  .events-hero__sub { font-family: 'Inter', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.65); margin: 0; max-width: 500px; }

  /* Event Feature Sections */
  .event-feature {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .event-feature--dark {
    background: var(--color-bg-dark, #0F0F0F);
  }

  .event-feature__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }

  .event-feature--reversed .event-feature__container {
    direction: rtl;
  }

  .event-feature--reversed .event-feature__container > * {
    direction: ltr;
  }

  .event-feature__image {
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .event-feature__image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .event-feature__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    margin-bottom: 1.25rem;
    background: rgba(139, 111, 71, 0.1);
    color: var(--color-accent, #8B6F47);
  }

  .event-feature--dark .event-feature__badge {
    background: rgba(198, 168, 108, 0.15);
    color: #C6A86C;
  }

  .event-feature__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.25rem;
  }

  .event-feature--dark .event-feature__title { color: #fff; }

  .event-feature__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0 0 1.25rem;
  }

  .event-feature--dark .event-feature__text { color: rgba(255,255,255,0.6); }

  .event-feature__detail {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.5rem;
  }

  .event-feature--dark .event-feature__detail { color: rgba(255,255,255,0.8); }

  .event-feature__awards {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: rgba(198, 168, 108, 0.08);
    border-radius: 0.75rem;
  }

  .event-feature__awards img {
    flex-shrink: 0;
  }

  .event-feature__awards div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
  }

  /* Events CTA */
  .events-cta {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    background: #F4F2EE;
    text-align: center;
  }

  .events-cta__inner { max-width: 500px; margin: 0 auto; }
  .events-cta__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 400; color: var(--color-text, #1A1A1A); margin: 0 0 1rem; }
  .events-cta__text { font-family: 'Inter', sans-serif; font-size: 1rem; color: var(--color-text-secondary, #6B6B6B); line-height: 1.7; margin: 0 0 1.5rem; }
  .events-cta__link { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: var(--color-accent, #8B6F47); text-decoration: none; transition: gap 0.3s; }
  .events-cta__link:hover { gap: 0.75rem; }

  @media (max-width: 768px) {
    .event-feature__container {
      grid-template-columns: 1fr;
    }
    .event-feature--reversed .event-feature__container {
      direction: ltr;
    }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
