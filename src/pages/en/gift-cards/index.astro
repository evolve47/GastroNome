---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/ui/Button.astro';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
const amounts = [500, 750, 1000, 1500, 2000, 3000];
---

<BaseLayout
  lang={lang}
  title={t(lang, 'gift.metaTitle')}
  description={t(lang, 'gift.metaDesc')}
>
  <!-- Hero Banner -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/652511994_18086431202349192_4627669848014543762_n.webp" alt="Cocktail at GASTRO|nome outdoor seating" loading="eager" fetchpriority="high" width="1200" height="480" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="page-hero__content">
      <span class="page-hero__eyebrow">Gift Cards</span>
      <h1 class="page-hero__title">Give the gift of an experience</h1>
    </div>
  </section>

  <!-- Gift Card Builder -->
  <section class="gc">
    <div class="gc__container">

      <!-- Left: intro copy + interactive card builder -->
      <div class="gc__builder fade-up">
        <h2 class="gc__builder-title">The perfect gift for every occasion</h2>
        <p class="gc__intro">
          {t(lang, 'gift.text1')}
        </p>

        <!-- Step 1: Amount -->
        <div class="gc__step">
          <span class="gc__step-num">1</span>
          <div class="gc__step-content">
            <h3 class="gc__step-title">Choose amount</h3>
            <div class="gc__amounts" id="amountGrid">
              {amounts.map((amt) => (
                <button
                  type="button"
                  class={`gc__amount-btn ${amt === 1000 ? 'is-selected' : ''}`}
                  data-amount={amt}
                >
                  {amt} kr
                </button>
              ))}
            </div>
            <div class="gc__custom-wrap">
              <label for="customAmount" class="gc__custom-label">Or enter a custom amount:</label>
              <div class="gc__custom-input-wrap">
                <input type="number" id="customAmount" class="gc__custom-input" min="100" max="10000" step="50" placeholder="1500" />
                <span class="gc__custom-suffix">kr</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Delivery -->
        <div class="gc__step">
          <span class="gc__step-num">2</span>
          <div class="gc__step-content">
            <h3 class="gc__step-title">Delivery method</h3>
            <div class="gc__delivery-options">
              <label class="gc__delivery-opt is-selected">
                <input type="radio" name="delivery" value="digital" checked class="gc__radio" />
                <div class="gc__delivery-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
                </div>
                <div>
                  <span class="gc__delivery-name">Digital</span>
                  <span class="gc__delivery-desc">Sent directly to the recipient's email</span>
                </div>
              </label>
              <label class="gc__delivery-opt">
                <input type="radio" name="delivery" value="physical" class="gc__radio" />
                <div class="gc__delivery-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>
                </div>
                <div>
                  <span class="gc__delivery-name">Physical card</span>
                  <span class="gc__delivery-desc">Pick up at our restaurant, Bangatan 6</span>
                </div>
              </label>
            </div>
          </div>
        </div>

        <!-- Step 3: Personal message -->
        <div class="gc__step">
          <span class="gc__step-num">3</span>
          <div class="gc__step-content">
            <h3 class="gc__step-title">Personal message</h3>
            <textarea id="gcMessage" class="gc__message" rows="3" placeholder="Happy birthday! Enjoy a fantastic evening..." maxlength="300"></textarea>
            <span class="gc__char-count"><span id="charCount">0</span>/300</span>
          </div>
        </div>

        <!-- CTA -->
        <button type="button" class="gc__submit" id="gcSubmit">
          <span class="gc__submit-text">Buy Gift Card</span>
          <span class="gc__submit-price" id="gcPrice">1 000 kr</span>
        </button>

        <p class="gc__demo-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          Demo — in production this connects to Stripe/Swish payment
        </p>
      </div>

      <!-- Right: preview card -->
      <div class="gc__preview fade-up">
        <div class="gc__card" id="gcCard">
          <div class="gc__card-bg"></div>
          <div class="gc__card-content">
            <div class="gc__card-top">
              <span class="gc__card-logo">GASTRO<span class="gc__card-pipe">|</span>nome</span>
              <span class="gc__card-label">Gift Card</span>
            </div>
            <div class="gc__card-middle">
              <span class="gc__card-amount" id="cardAmount">1 000 kr</span>
            </div>
            <div class="gc__card-msg" id="cardMsg">
              <em>Your message appears here...</em>
            </div>
            <div class="gc__card-bottom">
              <span class="gc__card-valid">Valid for 12 months</span>
              <span class="gc__card-loc">Bangatan 6, Lund</span>
            </div>
          </div>
        </div>

        <img src="/images/654113767_18086540393349192_9128637126260060053_n.webp" alt="Wine toast at GASTRO|nome" loading="lazy" decoding="async" width="600" height="450" class="gc__preview-bg" />

        <div class="gc__trust">
          <div class="gc__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure payment
          </div>
          <div class="gc__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Instant delivery
          </div>
          <div class="gc__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            12 months validity
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Fade-up animations handled by global observer in BaseLayout

  // Amount selection
  const amountBtns = document.querySelectorAll('.gc__amount-btn');
  const customInput = document.getElementById('customAmount') as HTMLInputElement;
  const gcPrice = document.getElementById('gcPrice');
  const cardAmount = document.getElementById('cardAmount');

  function formatKr(n: number) {
    return n.toLocaleString('sv-SE') + ' kr';
  }

  function setAmount(val: number) {
    if (gcPrice) gcPrice.textContent = formatKr(val);
    if (cardAmount) cardAmount.textContent = formatKr(val);
  }

  amountBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      amountBtns.forEach((b) => b.classList.remove('is-selected'));
      btn.classList.add('is-selected');
      if (customInput) customInput.value = '';
      setAmount(parseInt(btn.getAttribute('data-amount') || '1000', 10));
    });
  });

  if (customInput) {
    customInput.addEventListener('input', () => {
      amountBtns.forEach((b) => b.classList.remove('is-selected'));
      const val = parseInt(customInput.value, 10);
      if (val > 0) setAmount(val);
    });
  }

  // Delivery option toggle
  const deliveryOpts = document.querySelectorAll('.gc__delivery-opt');
  deliveryOpts.forEach((opt) => {
    const radio = opt.querySelector('input[type="radio"]') as HTMLInputElement;
    if (radio) {
      radio.addEventListener('change', () => {
        deliveryOpts.forEach((o) => o.classList.remove('is-selected'));
        opt.classList.add('is-selected');
      });
    }
  });

  // Message counter + live preview
  const msgInput = document.getElementById('gcMessage') as HTMLTextAreaElement;
  const charCount = document.getElementById('charCount');
  const cardMsg = document.getElementById('cardMsg');

  if (msgInput) {
    msgInput.addEventListener('input', () => {
      if (charCount) charCount.textContent = String(msgInput.value.length);
      if (cardMsg) {
        cardMsg.innerHTML = msgInput.value
          ? `<em>"${msgInput.value}"</em>`
          : '<em>Your message appears here...</em>';
      }
    });
  }

  // Demo submit
  const submitBtn = document.getElementById('gcSubmit');
  if (submitBtn) {
    submitBtn.addEventListener('click', () => {
      submitBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Gift card sent!';
      submitBtn.classList.add('gc__submit--success');
      setTimeout(() => {
        submitBtn.innerHTML = '<span class="gc__submit-text">Buy Gift Card</span><span class="gc__submit-price">' + (gcPrice?.textContent || '1 000 kr') + '</span>';
        submitBtn.classList.remove('gc__submit--success');
      }, 3000);
    });
  }
</script>

<style>
  /* Hero */
  .page-hero { position: relative; height: 40vh; min-height: 280px; max-height: 400px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a; }
  .page-hero__bg { position: absolute; inset: 0; }
  .page-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.25), rgba(0,0,0,0.6)); }
  .page-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .page-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .page-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.25rem, 5vw, 4rem); font-weight: 400; color: #fff; margin: 0; }

  /* Gift Card Section */
  .gc { padding: clamp(4rem, 8vw, 6rem) 1.5rem; background: var(--color-bg, #FAFAF9); }
  .gc__container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }

  /* Builder */
  .gc__builder {
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  }

  .gc__builder-title { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 500; color: var(--color-text, #1A1A1A); margin: 0 0 0.75rem; }
  .gc__intro { font-family: 'Inter', sans-serif; font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-secondary, #6B6B6B); margin: 0 0 2rem; }

  /* Steps */
  .gc__step { display: flex; gap: 1rem; margin-bottom: 2rem; }
  .gc__step-num { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: var(--color-accent, #8B6F47); color: #fff; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; display: flex; align-items: center; justify-content: center; margin-top: 0.125rem; }
  .gc__step-content { flex: 1; }
  .gc__step-title { font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: var(--color-text, #1A1A1A); margin: 0 0 0.875rem; }

  /* Amount grid */
  .gc__amounts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.625rem; margin-bottom: 1rem; }
  .gc__amount-btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem;
    border: 1.5px solid var(--color-border, #E8E5E0);
    border-radius: 0.625rem;
    background: #FAFAF9;
    color: var(--color-text, #1A1A1A);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .gc__amount-btn:hover { border-color: var(--color-accent, #8B6F47); color: var(--color-accent, #8B6F47); }
  .gc__amount-btn.is-selected { border-color: var(--color-accent, #8B6F47); background: var(--color-accent, #8B6F47); color: #fff; box-shadow: 0 2px 12px rgba(139,111,71,0.25); }

  .gc__custom-wrap { display: flex; flex-direction: column; gap: 0.375rem; }
  .gc__custom-label { font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: var(--color-text-secondary, #6B6B6B); }
  .gc__custom-input-wrap { display: flex; align-items: center; border: 1px solid var(--color-border, #E8E5E0); border-radius: 0.625rem; overflow: hidden; background: #FAFAF9; }
  .gc__custom-input { flex: 1; border: none; background: transparent; padding: 0.625rem 1rem; font-family: 'Inter', sans-serif; font-size: 0.9375rem; color: var(--color-text, #1A1A1A); outline: none; }
  .gc__custom-suffix { padding: 0 1rem; font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: var(--color-text-secondary, #6B6B6B); }

  /* Delivery options */
  .gc__delivery-options { display: flex; flex-direction: column; gap: 0.75rem; }
  .gc__delivery-opt {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem;
    border: 1.5px solid var(--color-border, #E8E5E0);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .gc__delivery-opt:hover { border-color: var(--color-accent, #8B6F47); }
  .gc__delivery-opt.is-selected { border-color: var(--color-accent, #8B6F47); background: rgba(139,111,71,0.04); }
  .gc__radio { display: none; }
  .gc__delivery-icon { flex-shrink: 0; width: 44px; height: 44px; border-radius: 0.625rem; background: rgba(139,111,71,0.08); display: flex; align-items: center; justify-content: center; color: var(--color-accent, #8B6F47); }
  .gc__delivery-name { display: block; font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 600; color: var(--color-text, #1A1A1A); }
  .gc__delivery-desc { display: block; font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: var(--color-text-secondary, #6B6B6B); margin-top: 0.125rem; }

  /* Message */
  .gc__message {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.625rem;
    background: #FAFAF9;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: var(--color-text, #1A1A1A);
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.2s ease;
  }
  .gc__message:focus { outline: none; border-color: var(--color-accent, #8B6F47); background: #fff; }
  .gc__char-count { display: block; text-align: right; font-family: 'Inter', sans-serif; font-size: 0.75rem; color: var(--color-text-secondary, #6B6B6B); margin-top: 0.25rem; }

  /* Submit */
  .gc__submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    margin-top: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #fff;
    background: var(--color-accent, #8B6F47);
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }
  .gc__submit:hover { background: #76593a; box-shadow: 0 6px 24px rgba(139,111,71,0.3); transform: translateY(-1px); }
  .gc__submit:active { transform: scale(0.98); }
  .gc__submit-price { background: rgba(255,255,255,0.2); padding: 0.25rem 0.75rem; border-radius: 2rem; font-size: 0.875rem; }
  .gc__submit--success { background: #2E7D32; gap: 0.5rem; }

  .gc__demo-note { display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem; font-family: 'Inter', sans-serif; font-size: 0.75rem; color: var(--color-text-secondary, #6B6B6B); justify-content: center; }

  /* Preview card */
  .gc__preview { position: relative; }
  .gc__preview-bg { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 0.75rem; display: block; }

  .gc__card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    max-width: 90%;
    z-index: 2;
  }

  .gc__card-bg {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 15, 0.88);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-radius: 1.25rem;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .gc__card-content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    color: #fff;
  }

  .gc__card-top { margin-bottom: 1.5rem; }
  .gc__card-logo { display: block; font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 500; letter-spacing: 0.02em; }
  .gc__card-pipe { color: #C6A86C; }
  .gc__card-label { display: block; font-family: 'Inter', sans-serif; font-size: 0.6875rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-top: 0.25rem; }
  .gc__card-middle { margin-bottom: 1rem; }
  .gc__card-amount { font-family: 'Cormorant Garamond', serif; font-size: 2.75rem; font-weight: 500; color: #C6A86C; line-height: 1; transition: all 0.3s ease; }
  .gc__card-msg { font-family: 'Inter', sans-serif; font-size: 0.8125rem; line-height: 1.5; color: rgba(255,255,255,0.5); min-height: 2.5rem; margin-bottom: 1.25rem; }
  .gc__card-bottom { display: flex; justify-content: space-between; font-family: 'Inter', sans-serif; font-size: 0.6875rem; color: rgba(255,255,255,0.35); }

  /* Trust badges */
  .gc__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .gc__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary, #6B6B6B);
  }

  .gc__trust-item svg { color: var(--color-accent, #8B6F47); }

  @media (max-width: 900px) {
    .gc__container { grid-template-columns: 1fr; }
    .gc__preview { order: -1; }
    .gc__card { position: relative; top: auto; left: auto; transform: none; width: 100%; margin-top: -4rem; }
    .gc__amounts { grid-template-columns: repeat(2, 1fr); }
    .gc__trust { flex-direction: column; gap: 0.75rem; align-items: center; }
  }

  /* fade-up animations handled by shared page styles */
</style>
