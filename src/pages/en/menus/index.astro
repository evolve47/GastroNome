---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { menu as menuCategories } from '../../../data/menu';
import { drinks as drinkCategories } from '../../../data/drinks';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title={t(lang, 'menus.metaTitle')}
  description={t(lang, 'menus.metaDesc')}
>
  <!-- Hero Banner -->
  <section class="menu-hero">
    <div class="menu-hero__bg">
      <img src="/images/640820505_18084012917349192_4427101478650068827_n.jpg" alt="Antipasti arrangement at GASTRO|nome" loading="eager" />
      <div class="menu-hero__overlay"></div>
    </div>
    <div class="menu-hero__content">
      <span class="menu-hero__eyebrow">{t(lang, 'menus.heroEyebrow')}</span>
      <h1 class="menu-hero__title">{t(lang, 'menus.heroTitle')}</h1>
      <p class="menu-hero__subtitle">{t(lang, 'menus.heroSubtitle')}</p>
    </div>
  </section>

  <!-- Menu Navigation -->
  <nav class="menu-nav" aria-label="Menu categories">
    <div class="menu-nav__inner">
      <div class="menu-nav__scroll">
        {menuCategories.map((cat) => (
          <a href={`#${cat.id}`} class="menu-nav__link">{cat.title}</a>
        ))}
        <span class="menu-nav__divider" aria-hidden="true"></span>
        <a href="#drinks" class="menu-nav__link">{t(lang, 'menus.drinksNav')}</a>
      </div>
    </div>
  </nav>

  <!-- Food Menu -->
  <div class="menu-content">
    {menuCategories.map((category) => (
      <section class="menu-section fade-up" id={category.id}>
        <div class="menu-section__header">
          <h2 class="menu-section__title">{category.title}</h2>
          {category.subtitle && (
            <p class="menu-section__subtitle">{category.subtitle}</p>
          )}
        </div>

        <div class="menu-section__items">
          {category.items.map((item) => (
            <div class={`menu-item ${item.award ? 'menu-item--featured' : ''}`}>
              <div class="menu-item__header">
                <h3 class="menu-item__name">
                  {item.name}
                  {item.award && (
                    <span class="menu-item__award">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                      </svg>
                      {item.award}
                    </span>
                  )}
                </h3>
                <span class="menu-item__dots" aria-hidden="true"></span>
                <span class="menu-item__price">{item.price} kr</span>
              </div>
              <p class="menu-item__desc">{item.description}</p>
              {item.tags && item.tags.length > 0 && (
                <div class="menu-item__tags">
                  {item.tags.map((tag) => (
                    <span class={`menu-tag menu-tag--${tag}`}>
                      {tag === 'vegetarian' ? t(lang, 'menus.tagVegetarian') :
                       tag === 'vegan' ? t(lang, 'menus.tagVegan') :
                       tag === 'veganOption' ? t(lang, 'menus.tagVeganOption') :
                       tag === 'glutenFreeOption' ? t(lang, 'menus.tagGlutenFreeOption') :
                       tag === 'award' ? t(lang, 'menus.tagAward') : tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>

        {category.note && (
          <p class="menu-section__note">{category.note}</p>
        )}
      </section>
    ))}

    <!-- Drinks Section -->
    <section class="menu-section menu-section--drinks fade-up" id="drinks">
      <div class="menu-section__header">
        <span class="menu-section__eyebrow">{t(lang, 'menus.drinksEyebrow')}</span>
        <h2 class="menu-section__title">{t(lang, 'menus.drinksTitle')}</h2>
      </div>

      {drinkCategories.map((category) => (
        <div class="drink-category fade-up">
          <h3 class="drink-category__title">{category.title}</h3>
          <div class="drink-category__items">
            {category.items.map((item) => (
              <div class="drink-item">
                <div class="drink-item__info">
                  <span class="drink-item__name">{item.name}</span>
                  {item.region && <span class="drink-item__region">{item.region}</span>}
                  {item.note && <span class="drink-item__note">{item.note}</span>}
                </div>
                <span class="drink-item__price">{item.price} kr</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Allergy Note -->
    <div class="menu-allergy fade-up">
      <p>
        <strong>{t(lang, 'menus.allergyTitle')}</strong> {t(lang, 'menus.allergyText')}
        <a href="tel:+46-46-390000">046-390000</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  // Scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));

  // Sticky menu nav highlight
  const sections = document.querySelectorAll('.menu-section');
  const navLinks = document.querySelectorAll('.menu-nav__link');

  const navObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navLinks.forEach((link) => {
            link.classList.toggle('is-active', link.getAttribute('href') === `#${id}`);
          });
        }
      });
    },
    { threshold: 0.2, rootMargin: '-100px 0px -60% 0px' }
  );
  sections.forEach((s) => navObserver.observe(s));
</script>

<style>
  /* Menu Hero */
  .menu-hero {
    position: relative;
    height: 50vh;
    min-height: 360px;
    max-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }

  .menu-hero__bg {
    position: absolute;
    inset: 0;
  }

  .menu-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .menu-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);
  }

  .menu-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .menu-hero__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.75rem;
  }

  .menu-hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    color: #fff;
    margin: 0 0 0.75rem;
  }

  .menu-hero__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    margin: 0;
  }

  /* Menu Navigation */
  .menu-nav {
    position: sticky;
    top: 60px;
    z-index: 40;
    background: rgba(250, 250, 249, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border, #E8E5E0);
  }

  .menu-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .menu-nav__scroll {
    display: flex;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0.75rem 0;
  }

  .menu-nav__scroll::-webkit-scrollbar { display: none; }

  .menu-nav__link {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #6B6B6B);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .menu-nav__link:hover {
    color: var(--color-text, #1A1A1A);
    background: rgba(0,0,0,0.04);
  }

  .menu-nav__link.is-active {
    color: #fff;
    background: var(--color-text, #1A1A1A);
  }

  .menu-nav__divider {
    width: 1px;
    background: var(--color-border, #E8E5E0);
    margin: 0 0.5rem;
    flex-shrink: 0;
  }

  /* Menu Content */
  .menu-content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .menu-section {
    padding: clamp(3rem, 5vw, 5rem) 0;
    scroll-margin-top: 7.5rem;
    border-bottom: 1px solid var(--color-border, #E8E5E0);
  }

  .menu-section:last-of-type {
    border-bottom: none;
  }

  .menu-section__header {
    margin-bottom: 2.5rem;
  }

  .menu-section__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent, #8B6F47);
    margin-bottom: 0.75rem;
  }

  .menu-section__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text, #1A1A1A);
    margin: 0;
  }

  .menu-section__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0.5rem 0 0;
  }

  .menu-section__note {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #6B6B6B);
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border, #E8E5E0);
    font-style: italic;
  }

  /* Menu Items */
  .menu-section__items {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .menu-item {
    position: relative;
  }

  .menu-item--featured {
    background: rgba(139, 111, 71, 0.04);
    border-radius: 0.75rem;
    padding: 1.25rem;
    margin: -0.5rem -1.25rem;
  }

  .menu-item__header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .menu-item__name {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text, #1A1A1A);
    margin: 0;
    white-space: nowrap;
  }

  .menu-item__award {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #C6A86C;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .menu-item__dots {
    flex: 1;
    border-bottom: 1px dotted var(--color-border, #E8E5E0);
    min-width: 2rem;
    margin-bottom: 0.25rem;
  }

  .menu-item__price {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #1A1A1A);
    white-space: nowrap;
  }

  .menu-item__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0.375rem 0 0;
  }

  .menu-item__tags {
    display: flex;
    gap: 0.375rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .menu-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.1875rem 0.5rem;
    border-radius: 1rem;
    letter-spacing: 0.02em;
  }

  .menu-tag--vegetarian {
    background: #E8F5E9;
    color: #2E7D32;
  }

  .menu-tag--vegan {
    background: #E0F2F1;
    color: #00695C;
  }

  .menu-tag--veganOption {
    background: #F3E5F5;
    color: #6A1B9A;
  }

  .menu-tag--glutenFreeOption {
    background: #FFF3E0;
    color: #E65100;
  }

  .menu-tag--award {
    background: #FFF8E1;
    color: #F57F17;
  }

  /* Drinks */
  .drink-category {
    margin-bottom: 2.5rem;
  }

  .drink-category__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border, #E8E5E0);
  }

  .drink-category__items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .drink-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .drink-item__info {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.375rem;
  }

  .drink-item__name {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text, #1A1A1A);
  }

  .drink-item__region {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #6B6B6B);
  }

  .drink-item__note {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-style: italic;
    color: var(--color-accent, #8B6F47);
  }

  .drink-item__price {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text, #1A1A1A);
    white-space: nowrap;
  }

  /* Allergy Note */
  .menu-allergy {
    text-align: center;
    padding: 2.5rem 0 4rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #6B6B6B);
  }

  .menu-allergy a {
    color: var(--color-accent, #8B6F47);
    text-decoration: none;
    font-weight: 500;
  }

  .menu-allergy a:hover {
    text-decoration: underline;
  }

  /* Animations */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);
  }
  .fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up { opacity: 1; transform: none; transition: none; }
  }
</style>
