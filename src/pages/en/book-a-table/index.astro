---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/ui/Button.astro';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title={t(lang, 'booking.metaTitle')}
  description={t(lang, 'booking.metaDesc')}
>
  <section class="booking">
    <div class="booking__container">
      <div class="booking__content fade-up">
        <span class="booking__eyebrow">{t(lang, 'booking.eyebrow')}</span>
        <h1 class="booking__title">{t(lang, 'booking.title')}</h1>
        <p class="booking__text">{t(lang, 'booking.text')}</p>

        <div class="booking__options">
          <a href="tel:+46-46-390000" class="booking__option">
            <div class="booking__option-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
              </svg>
            </div>
            <div>
              <h3 class="booking__option-title">{t(lang, 'booking.callUs')}</h3>
              <p class="booking__option-detail">046-390000</p>
            </div>
          </a>

          <a href="mailto:info@gastronome.se" class="booking__option">
            <div class="booking__option-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 7l-10 7L2 7" />
              </svg>
            </div>
            <div>
              <h3 class="booking__option-title">{t(lang, 'booking.emailUs')}</h3>
              <p class="booking__option-detail">info@gastronome.se</p>
            </div>
          </a>

          <a href="https://www.instagram.com/gastronomelund" target="_blank" rel="noopener noreferrer" class="booking__option">
            <div class="booking__option-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
              </svg>
            </div>
            <div>
              <h3 class="booking__option-title">{t(lang, 'booking.instagramDm')}</h3>
              <p class="booking__option-detail">@gastronomelund</p>
            </div>
          </a>
        </div>
      </div>

      <div class="booking__image fade-up">
        <img src="/images/615490572_1574239250966126_6866087512718104938_n.jpg" alt="Bar at GASTRO|nome with atmospheric lighting" loading="lazy" />
        <div class="booking__hours">
          <h3 class="booking__hours-title">{t(lang, 'booking.hoursTitle')}</h3>
          <dl class="booking__hours-list">
            <div class="booking__hours-row booking__hours-row--closed">
              <dt>{t(lang, 'hours.monday')}</dt><dd>{t(lang, 'hours.closed')}</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.tuesday')}</dt><dd>17:00–22:00</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.wednesday')}</dt><dd>17:00–23:00</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.thursday')}</dt><dd>17:00–23:00</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.friday')}</dt><dd>15:00–00:00</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.saturday')}</dt><dd>15:00–00:00</dd>
            </div>
            <div class="booking__hours-row">
              <dt>{t(lang, 'hours.sunday')}</dt><dd>15:00–22:00</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- Map -->
    <div class="booking__map fade-up">
      <div class="booking__map-info">
        <h2 class="booking__map-title">{t(lang, 'booking.findUs')}</h2>
        <p class="booking__map-address">Bangatan 6, 222 21 Lund</p>
        <p class="booking__map-note">{t(lang, 'booking.nearStation')}</p>
      </div>
      <div class="booking__map-embed">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2246.1!2d13.191!3d55.7047!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTXCsDQyJzE3LjAiTiAxM8KwMTEnMjcuNiJF!5e0!3m2!1sen!2sse!4v1"
          width="100%"
          height="400"
          style="border:0; border-radius: 0.75rem;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          sandbox="allow-scripts allow-same-origin allow-popups"
          title={t(lang, 'booking.mapTitle')}
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

<style>
  .booking {
    padding: clamp(5rem, 10vw, 8rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .booking__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
  }

  .booking__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent, #8B6F47);
    margin-bottom: 1rem;
    position: relative;
    padding-left: 3rem;
  }
  .booking__eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 2rem;
    height: 1px;
    background: var(--color-accent, #8B6F47);
  }

  .booking__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.25rem;
  }

  .booking__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0 0 2.5rem;
    max-width: 460px;
  }

  .booking__options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .booking__option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .booking__option:hover {
    border-color: var(--color-accent, #8B6F47);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transform: translateY(-1px);
  }

  .booking__option-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(139, 111, 71, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-accent, #8B6F47);
  }

  .booking__option-title {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text, #1A1A1A);
    margin: 0;
  }

  .booking__option-detail {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0.125rem 0 0;
  }

  .booking__image {
    position: relative;
  }

  .booking__image img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

  .booking__hours {
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  .booking__hours-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .booking__hours-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .booking__hours-row {
    display: flex;
    justify-content: space-between;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
  }

  .booking__hours-row dt { color: var(--color-text, #1A1A1A); }
  .booking__hours-row dd { margin: 0; font-weight: 500; color: var(--color-text, #1A1A1A); }
  .booking__hours-row--closed dd { color: var(--color-text-secondary, #6B6B6B); font-style: italic; }

  /* Map */
  .booking__map {
    max-width: 1200px;
    margin: clamp(4rem, 8vw, 6rem) auto 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: start;
  }

  .booking__map-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 0.5rem;
  }

  .booking__map-address {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 0.25rem;
  }

  .booking__map-note {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0;
  }

  @media (max-width: 768px) {
    .booking__container { grid-template-columns: 1fr; }
    .booking__map { grid-template-columns: 1fr; }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
