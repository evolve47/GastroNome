---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Stora Sällskap — GASTRO|nome Mat & Bar | Privata Middagar i Lund"
  description="Planera din fest på GASTRO|nome. Skräddarsydda menyer för grupper från 9 personer. Privat våningsplan, företagsmiddagar och familjefester. Boka nu!"
>
  <!-- Hero -->
  <section class="ss-hero">
    <div class="ss-hero__bg">
      <img src="/images/609688280_18078667205349192_8969733676829862513_n.webp" alt="Grupp som skålar på GASTRO|nome" loading="eager" />
      <div class="ss-hero__overlay"></div>
    </div>
    <div class="ss-hero__content">
      <span class="ss-hero__eyebrow">Stora Sällskap</span>
      <h1 class="ss-hero__title">Er kväll,<br />vår passion</h1>
      <p class="ss-hero__sub">Skräddarsydda menyer och privat atmosfär för grupper från 9 personer</p>
    </div>
  </section>

  <!-- Info -->
  <section class="ss-info">
    <div class="ss-info__container">
      <div class="ss-info__content fade-up">
        <h2 class="ss-info__title">Hur det fungerar</h2>
        <p class="ss-info__text">
          För sällskap med 8 eller fler gäster erbjuder vi ett specialanpassat menyupplägg.
          Ni väljer rätter ur vår meny och vi tar hand om resten. Vårt andra våningsplan med sin
          eleganta och avskilda atmosfär är perfekt för större tillställningar.
        </p>

        <div class="ss-details">
          <div class="ss-detail">
            <h3 class="ss-detail__title">Menyformat</h3>
            <p class="ss-detail__text">2-rätters (förrätt + huvudrätt eller huvudrätt + dessert) som standard. Uppgradering till 3-rätters finns.</p>
          </div>
          <div class="ss-detail">
            <h3 class="ss-detail__title">Val baserat på antal</h3>
            <ul class="ss-detail__list">
              <li>9–14 gäster: välj bland 6 alternativ per kategori</li>
              <li>15–19 gäster: välj bland 5 alternativ per kategori</li>
              <li>20+ gäster: välj bland 3 alternativ per kategori</li>
            </ul>
          </div>
          <div class="ss-detail">
            <h3 class="ss-detail__title">Viktiga datum</h3>
            <ul class="ss-detail__list">
              <li>Menyval senast 5 dagar innan</li>
              <li>Ändring av antal senast kl 12:00 samma dag</li>
              <li>Avbokning senast 7 dagar innan (450 kr/gäst vid sen avbokning)</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="ss-info__image fade-up">
        <img src="/images/the-restaurant-2nd-floor.webp" alt="GASTRO|nome andra våningen — privat matsal" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="ss-form" id="boka">
    <div class="ss-form__container">
      <div class="ss-form__header fade-up">
        <h2 class="ss-form__title">Boka för ert sällskap</h2>
        <p class="ss-form__subtitle">Fyll i formuläret så återkommer vi inom 24 timmar</p>
      </div>

      <form class="form fade-up" action="https://formsubmit.co/info@gastronome.se" method="POST">
        <input type="hidden" name="_subject" value="Stora Sällskap — Ny förfrågan via hemsidan" />
        <input type="hidden" name="_template" value="box" />
        <input type="text" name="_honey" style="display:none" />
        <input type="hidden" name="_captcha" value="true" />

        <div class="form__grid">
          <div class="form__field">
            <label for="name" class="form__label">Namn</label>
            <input type="text" id="name" name="name" required maxlength="100" autocomplete="name" class="form__input" placeholder="Ditt namn" />
          </div>
          <div class="form__field">
            <label for="email" class="form__label">E-post</label>
            <input type="email" id="email" name="email" required maxlength="200" autocomplete="email" class="form__input" placeholder="din@email.se" />
          </div>
          <div class="form__field">
            <label for="phone" class="form__label">Telefon</label>
            <input type="tel" id="phone" name="phone" maxlength="20" pattern="[0-9\-\+\s\(\)]+" autocomplete="tel" class="form__input" placeholder="070-xxx xxxx" />
          </div>
          <div class="form__field">
            <label for="guests" class="form__label">Antal gäster</label>
            <input type="number" id="guests" name="guests" min="8" max="200" required class="form__input" placeholder="9" />
          </div>
          <div class="form__field">
            <label for="date" class="form__label">Önskat datum</label>
            <input type="date" id="date" name="date" required class="form__input" />
          </div>
          <div class="form__field">
            <label for="type" class="form__label">Typ av tillställning</label>
            <select id="type" name="type" class="form__input">
              <option value="">Välj...</option>
              <option value="Födelsedag">Födelsedag</option>
              <option value="Firmafest">Firmafest / afterwork</option>
              <option value="Familjemiddag">Familjemiddag</option>
              <option value="Bröllop">Bröllop / förlovning</option>
              <option value="Annat">Annat</option>
            </select>
          </div>
        </div>

        <div class="form__field form__field--full">
          <label for="message" class="form__label">Meddelande</label>
          <textarea id="message" name="message" rows="4" maxlength="2000" class="form__input form__textarea" placeholder="Berätta mer om ert event, önskemål eller frågor..."></textarea>
        </div>

        <div class="form__submit">
          <Button variant="primary" size="lg" type="submit">Skicka Förfrågan</Button>
        </div>
      </form>
    </div>
  </section>

  <!-- Alternative Contact -->
  <section class="ss-alt">
    <div class="ss-alt__inner fade-up">
      <p class="ss-alt__text">Föredrar du att ringa? Kontakta oss direkt på</p>
      <a href="tel:+46-46-390000" class="ss-alt__phone">046-390000</a>
      <p class="ss-alt__or">eller maila <a href="mailto:info@gastronome.se">info@gastronome.se</a></p>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

<style>
  /* Hero */
  .ss-hero { position: relative; height: 50vh; min-height: 360px; max-height: 500px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a; }
  .ss-hero__bg { position: absolute; inset: 0; }
  .ss-hero__bg img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.3); }
  .ss-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.2), rgba(0,0,0,0.65)); }
  .ss-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .ss-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .ss-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 400; color: #fff; margin: 0 0 0.75rem; }
  .ss-hero__sub { font-family: 'Inter', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.65); margin: 0; }

  /* Info Section */
  .ss-info { padding: clamp(5rem, 10vw, 8rem) 1.5rem; background: var(--color-bg, #FAFAF9); }
  .ss-info__container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(3rem, 5vw, 5rem); align-items: start; }
  .ss-info__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 400; color: var(--color-text, #1A1A1A); margin: 0 0 1.5rem; }
  .ss-info__text { font-family: 'Inter', sans-serif; font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary, #6B6B6B); margin: 0 0 2.5rem; }
  .ss-info__image { border-radius: 0.75rem; overflow: hidden; position: sticky; top: 6rem; }
  .ss-info__image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

  .ss-details { display: flex; flex-direction: column; gap: 2rem; }
  .ss-detail { padding: 1.5rem; background: #fff; border: 1px solid var(--color-border, #E8E5E0); border-radius: 0.75rem; }
  .ss-detail__title { font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: var(--color-text, #1A1A1A); margin: 0 0 0.75rem; }
  .ss-detail__text { font-family: 'Inter', sans-serif; font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-secondary, #6B6B6B); margin: 0; }
  .ss-detail__list { font-family: 'Inter', sans-serif; font-size: 0.9375rem; line-height: 1.8; color: var(--color-text-secondary, #6B6B6B); margin: 0; padding-left: 1.25rem; }

  /* Form Section */
  .ss-form { padding: clamp(5rem, 10vw, 8rem) 1.5rem; background: #F4F2EE; }
  .ss-form__container { max-width: 720px; margin: 0 auto; }
  .ss-form__header { text-align: center; margin-bottom: 3rem; }
  .ss-form__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3.5vw, 2.75rem); font-weight: 400; color: var(--color-text, #1A1A1A); margin: 0 0 0.75rem; }
  .ss-form__subtitle { font-family: 'Inter', sans-serif; font-size: 1rem; color: var(--color-text-secondary, #6B6B6B); margin: 0; }

  .form__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
  .form__field { display: flex; flex-direction: column; gap: 0.375rem; }
  .form__field--full { margin-bottom: 1.5rem; }
  .form__label { font-family: 'Inter', sans-serif; font-size: 0.8125rem; font-weight: 500; color: var(--color-text, #1A1A1A); }
  .form__input {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.5rem;
    background: #fff;
    color: var(--color-text, #1A1A1A);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }
  .form__input:focus { outline: none; border-color: var(--color-accent, #8B6F47); box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.1); }
  .form__textarea { resize: vertical; min-height: 100px; }
  .form__submit { text-align: center; }

  /* Alt Contact */
  .ss-alt { padding: 3rem 1.5rem 4rem; text-align: center; background: var(--color-bg, #FAFAF9); }
  .ss-alt__text { font-family: 'Inter', sans-serif; font-size: 0.9375rem; color: var(--color-text-secondary, #6B6B6B); margin: 0 0 0.5rem; }
  .ss-alt__phone { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 500; color: var(--color-text, #1A1A1A); text-decoration: none; display: block; margin-bottom: 0.5rem; }
  .ss-alt__or { font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--color-text-secondary, #6B6B6B); margin: 0; }
  .ss-alt__or a { color: var(--color-accent, #8B6F47); text-decoration: none; }

  @media (max-width: 768px) {
    .ss-info__container { grid-template-columns: 1fr; }
    .ss-info__image { position: static; }
    .form__grid { grid-template-columns: 1fr; }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
