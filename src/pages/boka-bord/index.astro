---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Boka Bord — GASTRO|nome Mat & Bar | Reservera i Lund"
  description="Boka bord på GASTRO|nome, Lunds #1 restaurang. Ring 046-390000 eller boka online. Bangatan 6, 222 21 Lund."
>
  <!-- Hero Banner -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/615490572_1574239250966126_6866087512718104938_n.jpg" alt="Bar på GASTRO|nome" loading="eager" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="page-hero__content">
      <span class="page-hero__eyebrow">Reservera</span>
      <h1 class="page-hero__title">Boka Bord</h1>
      <p class="page-hero__sub">Reservera er kväll på Lunds #1 restaurang</p>
    </div>
  </section>

  <!-- Booking Widget Demo -->
  <section class="booking-widget" id="boka">
    <div class="booking-widget__container">
      <div class="booking-widget__form-wrap fade-up">
        <div class="booking-widget__header">
          <h2 class="booking-widget__title">Välj datum & tid</h2>
          <p class="booking-widget__subtitle">Direktbokning — bekräftelse via e-post</p>
        </div>

        <form class="bform" id="bookingForm">
          <div class="bform__row">
            <div class="bform__field">
              <label for="b-date" class="bform__label">Datum</label>
              <input type="date" id="b-date" class="bform__input" required />
            </div>
            <div class="bform__field">
              <label for="b-time" class="bform__label">Tid</label>
              <select id="b-time" class="bform__input" required>
                <option value="">Välj tid...</option>
                <option>17:00</option>
                <option>17:30</option>
                <option>18:00</option>
                <option>18:30</option>
                <option>19:00</option>
                <option>19:30</option>
                <option>20:00</option>
                <option>20:30</option>
                <option>21:00</option>
              </select>
            </div>
          </div>

          <div class="bform__row">
            <div class="bform__field">
              <label for="b-guests" class="bform__label">Antal gäster</label>
              <div class="bform__counter" id="guestCounter">
                <button type="button" class="bform__counter-btn" data-action="decrease" aria-label="Minska">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
                </button>
                <span class="bform__counter-value" id="guestCount">2</span>
                <input type="hidden" id="b-guests" name="guests" value="2" />
                <button type="button" class="bform__counter-btn" data-action="increase" aria-label="Öka">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>
            </div>
            <div class="bform__field">
              <label for="b-area" class="bform__label">Önskemål</label>
              <select id="b-area" class="bform__input">
                <option value="">Inget speciellt</option>
                <option>Fönsterplats</option>
                <option>Barplats</option>
                <option>Övre våningen</option>
                <option>Uteservering</option>
              </select>
            </div>
          </div>

          <div class="bform__divider"></div>

          <div class="bform__row">
            <div class="bform__field">
              <label for="b-name" class="bform__label">Namn</label>
              <input type="text" id="b-name" class="bform__input" placeholder="Ditt fullständiga namn" required autocomplete="name" maxlength="100" />
            </div>
            <div class="bform__field">
              <label for="b-phone" class="bform__label">Telefon</label>
              <input type="tel" id="b-phone" class="bform__input" placeholder="070-xxx xxxx" required autocomplete="tel" maxlength="20" />
            </div>
          </div>

          <div class="bform__field">
            <label for="b-email" class="bform__label">E-post</label>
            <input type="email" id="b-email" class="bform__input" placeholder="din@email.se" required autocomplete="email" />
          </div>

          <div class="bform__field">
            <label for="b-note" class="bform__label">Meddelande <span class="bform__optional">(valfritt)</span></label>
            <textarea id="b-note" class="bform__input bform__textarea" rows="2" placeholder="Allergier, firande, önskemål..." maxlength="500"></textarea>
          </div>

          <button type="submit" class="bform__submit">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Bekräfta Bokning
          </button>

          <p class="bform__note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            Demo — i produktion kopplas detta till ett riktigt bokningssystem
          </p>
        </form>
      </div>

      <!-- Right side: info + hours -->
      <div class="booking-widget__info fade-up">
        <div class="booking-widget__hours">
          <h3 class="booking-widget__hours-title">Öppettider</h3>
          <dl class="booking-widget__hours-list">
            <div class="bh-row bh-row--closed"><dt>Måndag</dt><dd>Stängt</dd></div>
            <div class="bh-row"><dt>Tisdag</dt><dd>17:00–22:00</dd></div>
            <div class="bh-row"><dt>Onsdag</dt><dd>17:00–23:00</dd></div>
            <div class="bh-row"><dt>Torsdag</dt><dd>17:00–23:00</dd></div>
            <div class="bh-row"><dt>Fredag</dt><dd>15:00–00:00</dd></div>
            <div class="bh-row"><dt>Lördag</dt><dd>15:00–00:00</dd></div>
            <div class="bh-row"><dt>Söndag</dt><dd>15:00–22:00</dd></div>
          </dl>
        </div>

        <div class="booking-widget__contact">
          <h3 class="booking-widget__contact-title">Föredrar du att ringa?</h3>
          <a href="tel:+46-46-390000" class="booking-widget__phone">046-390000</a>
          <p class="booking-widget__email">eller <a href="mailto:info@gastronome.se">info@gastronome.se</a></p>
        </div>

        <div class="booking-widget__address">
          <div class="booking-widget__address-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="booking-widget__address-text">Bangatan 6, 222 21 Lund</p>
            <p class="booking-widget__address-note">I hjärtat av Lund, nära stationen</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section">
    <div class="map-section__inner">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2246.1!2d13.191!3d55.7047!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTXCsDQyJzE3LjAiTiAxM8KwMTEnMjcuNiJF!5e0!3m2!1ssv!2sse!4v1"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        sandbox="allow-scripts allow-same-origin allow-popups"
        title="GASTRO|nome karta"
      ></iframe>
    </div>
  </section>
</BaseLayout>

<script>
  // Animations
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));

  // Guest counter
  const guestCount = document.getElementById('guestCount');
  const guestInput = document.getElementById('b-guests') as HTMLInputElement;
  const counter = document.getElementById('guestCounter');
  if (counter && guestCount && guestInput) {
    counter.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]');
      if (!btn) return;
      let val = parseInt(guestInput.value, 10);
      if (btn.getAttribute('data-action') === 'increase' && val < 20) val++;
      if (btn.getAttribute('data-action') === 'decrease' && val > 1) val--;
      guestInput.value = String(val);
      guestCount.textContent = String(val);
    });
  }

  // Demo booking form
  const form = document.getElementById('bookingForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('.bform__submit') as HTMLButtonElement;
      btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Bokning bekräftad!';
      btn.classList.add('bform__submit--success');
      btn.disabled = true;
      setTimeout(() => {
        btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Bekräfta Bokning';
        btn.classList.remove('bform__submit--success');
        btn.disabled = false;
      }, 3000);
    });
  }

  // Set min date to today
  const dateInput = document.getElementById('b-date') as HTMLInputElement;
  if (dateInput) {
    const today = new Date().toISOString().split('T')[0];
    dateInput.min = today;
    dateInput.value = today;
  }
</script>

<style>
  /* Hero */
  .page-hero { position: relative; height: 45vh; min-height: 300px; max-height: 450px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a; }
  .page-hero__bg { position: absolute; inset: 0; }
  .page-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.3), rgba(0,0,0,0.65)); }
  .page-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .page-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .page-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 400; color: #fff; margin: 0 0 0.5rem; }
  .page-hero__sub { font-family: 'Inter', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.55); margin: 0; }

  /* Booking Widget */
  .booking-widget {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .booking-widget__container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .booking-widget__form-wrap {
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  }

  .booking-widget__header { margin-bottom: 2rem; }
  .booking-widget__title { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 500; color: var(--color-text, #1A1A1A); margin: 0 0 0.375rem; }
  .booking-widget__subtitle { font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--color-text-secondary, #6B6B6B); margin: 0; }

  /* Form */
  .bform__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .bform__field { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 0.5rem; }
  .bform__label { font-family: 'Inter', sans-serif; font-size: 0.8125rem; font-weight: 500; color: var(--color-text, #1A1A1A); }
  .bform__optional { font-weight: 400; color: var(--color-text-secondary, #6B6B6B); }

  .bform__input {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.625rem;
    background: #FAFAF9;
    color: var(--color-text, #1A1A1A);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .bform__input:focus {
    outline: none;
    border-color: var(--color-accent, #8B6F47);
    box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.08);
    background: #fff;
  }

  .bform__textarea { resize: vertical; min-height: 60px; }
  .bform__divider { height: 1px; background: var(--color-border, #E8E5E0); margin: 1.25rem 0; }

  /* Guest counter */
  .bform__counter {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 0.625rem;
    overflow: hidden;
    background: #FAFAF9;
  }

  .bform__counter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: none;
    background: transparent;
    color: var(--color-text-secondary, #6B6B6B);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .bform__counter-btn:hover {
    background: rgba(139, 111, 71, 0.08);
    color: var(--color-accent, #8B6F47);
  }

  .bform__counter-value {
    flex: 1;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text, #1A1A1A);
    min-width: 3rem;
  }

  /* Submit button */
  .bform__submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1rem;
    margin-top: 1.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #fff;
    background: var(--color-accent, #8B6F47);
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }

  .bform__submit:hover {
    background: #76593a;
    box-shadow: 0 6px 24px rgba(139, 111, 71, 0.3);
    transform: translateY(-1px);
  }

  .bform__submit:active { transform: scale(0.98); }

  .bform__submit--success {
    background: #2E7D32;
    pointer-events: none;
  }

  .bform__note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--color-text-secondary, #6B6B6B);
    justify-content: center;
  }

  /* Right side info */
  .booking-widget__info { display: flex; flex-direction: column; gap: 1.5rem; }

  .booking-widget__hours {
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 1rem;
    padding: 1.75rem;
  }

  .booking-widget__hours-title { font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-secondary, #6B6B6B); margin: 0 0 1rem; }
  .booking-widget__hours-list { margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .bh-row { display: flex; justify-content: space-between; font-family: 'Inter', sans-serif; font-size: 0.9375rem; }
  .bh-row dt { color: var(--color-text, #1A1A1A); }
  .bh-row dd { margin: 0; font-weight: 500; color: var(--color-text, #1A1A1A); }
  .bh-row--closed dd { color: var(--color-text-secondary, #6B6B6B); font-style: italic; }

  .booking-widget__contact {
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 1rem;
    padding: 1.75rem;
    text-align: center;
  }

  .booking-widget__contact-title { font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--color-text-secondary, #6B6B6B); margin: 0 0 0.75rem; }
  .booking-widget__phone { display: block; font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 500; color: var(--color-text, #1A1A1A); text-decoration: none; margin-bottom: 0.375rem; transition: color 0.2s; }
  .booking-widget__phone:hover { color: var(--color-accent, #8B6F47); }
  .booking-widget__email { font-family: 'Inter', sans-serif; font-size: 0.875rem; color: var(--color-text-secondary, #6B6B6B); margin: 0; }
  .booking-widget__email a { color: var(--color-accent, #8B6F47); text-decoration: none; }

  .booking-widget__address {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    background: #fff;
    border: 1px solid var(--color-border, #E8E5E0);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
  }

  .booking-widget__address-icon { color: var(--color-accent, #8B6F47); flex-shrink: 0; margin-top: 0.125rem; }
  .booking-widget__address-text { font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 500; color: var(--color-text, #1A1A1A); margin: 0 0 0.125rem; }
  .booking-widget__address-note { font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: var(--color-text-secondary, #6B6B6B); margin: 0; }

  /* Map */
  .map-section { background: var(--color-bg, #FAFAF9); padding: 0 0 0; }
  .map-section__inner { max-width: 100%; }
  .map-section__inner iframe { display: block; width: 100%; height: 350px; }

  @media (max-width: 768px) {
    .booking-widget__container { grid-template-columns: 1fr; }
    .bform__row { grid-template-columns: 1fr; }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
