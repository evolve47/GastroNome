---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Evenemang — GASTRO|nome Mat & Bar | Bubbeltorsdag & Specialkvällar"
  description="Upptäck GASTRO|nome's evenemang. Bubbeltorsdag varje vecka, säsongsmenyer, vinprovningar och privata tillställningar. Bangatan 6, Lund."
>
  <!-- Hero -->
  <section class="events-hero">
    <div class="events-hero__bg">
      <img src="/images/2026-02-20.webp" alt="Romantisk dukning med rosenblad och ljus på GASTRO|nome" loading="eager" />
      <div class="events-hero__overlay"></div>
    </div>
    <div class="events-hero__content">
      <span class="events-hero__eyebrow">Evenemang</span>
      <h1 class="events-hero__title">Upplevelser som<br />stannar kvar</h1>
      <p class="events-hero__sub">Från Bubbeltorsdagar till privata fester — det finns alltid något att se fram emot</p>
    </div>
  </section>

  <!-- Recurring: Bubbeltorsdag -->
  <section class="event-feature">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/619226756_18080282837349192_8699460402074805794_n.webp" alt="Champagne hälls i glas" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">Varje Torsdag</span>
        <h2 class="event-feature__title">Bubbeltorsdag</h2>
        <p class="event-feature__text">
          Starta torsdagskvällen rätt. Varje vecka bjuder vi på bubbel och nybakade flatbread
          fram till klockan 19:00. Perfekt för en afterwork eller en mysig start på kvällen med vänner.
        </p>
        <p class="event-feature__detail">
          <strong>När:</strong> Varje torsdag, 17:00–19:00<br />
          <strong>Erbjudande:</strong> Bubbel + flatbread
        </p>
        <Button href="/boka-bord/" variant="primary">Boka Bord</Button>
      </div>
    </div>
  </section>

  <!-- Pizza SM -->
  <section class="event-feature event-feature--reversed event-feature--dark">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/fc037b4ad21057456dde5a40cd6d09f2-thumb_large.webp" alt="SM-vinnande margheritapizza" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">2023 & 2024</span>
        <h2 class="event-feature__title">Pizza SM Champions</h2>
        <p class="event-feature__text">
          Två år i rad har vi tagit hem guldmedaljen i Svenska Mästerskapen i Pizza.
          Våra vinnarrecept — <em>Filetto alla GASTRO</em> och <em>Cavolo Meraviglioso</em> —
          finns på den ordinarie menyn. Smaka själv varför domarna var eniga.
        </p>
        <div class="event-feature__awards">
          <img src="/images/pizza-champion-cup.webp" alt="Pizza SM trophy" width="48" height="48" />
          <div>
            <span>Filetto alla GASTRO — 1:a plats 2024</span>
            <span>Cavolo Meraviglioso — 1:a plats 2023</span>
          </div>
        </div>
        <Button href="/menyer/" variant="outline">Se Menyn</Button>
      </div>
    </div>
  </section>

  <!-- Stora Sällskap -->
  <section class="event-feature">
    <div class="event-feature__container">
      <div class="event-feature__image fade-up">
        <img src="/images/467249171_18037063073349192_5208946929036331443_n.webp" alt="Stort middagssällskap" loading="lazy" />
      </div>
      <div class="event-feature__content fade-up">
        <span class="event-feature__badge">9+ gäster</span>
        <h2 class="event-feature__title">Stora Sällskap</h2>
        <p class="event-feature__text">
          Planerar du en födelsedag, firmafest eller familjemiddag? Vi skräddarsyr menyer
          för grupper från 9 personer och uppåt. Vårt andra våningsplan erbjuder en privat
          och elegant atmosfär för era tillställningar.
        </p>
        <Button href="/stora-sallskap/" variant="primary">Läs Mer & Boka</Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="events-cta">
    <div class="events-cta__inner fade-up">
      <h2 class="events-cta__title">Vill du vara först med att veta?</h2>
      <p class="events-cta__text">Följ oss på Instagram för att hålla koll på kommande evenemang och säsongsmenyer.</p>
      <a href="https://www.instagram.com/gastronomelund" target="_blank" rel="noopener noreferrer" class="events-cta__link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
        </svg>
        @gastronomelund
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

<style>
  .events-hero {
    position: relative;
    height: 50vh;
    min-height: 360px;
    max-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }
  .events-hero__bg { position: absolute; inset: 0; }
  .events-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .events-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.2), rgba(0,0,0,0.6)); }
  .events-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .events-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .events-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 400; color: #fff; margin: 0 0 0.75rem; }
  .events-hero__sub { font-family: 'Inter', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.65); margin: 0; max-width: 500px; }

  /* Event Feature Sections */
  .event-feature {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .event-feature--dark {
    background: var(--color-bg-dark, #0F0F0F);
  }

  .event-feature__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }

  .event-feature--reversed .event-feature__container {
    direction: rtl;
  }

  .event-feature--reversed .event-feature__container > * {
    direction: ltr;
  }

  .event-feature__image {
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .event-feature__image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .event-feature__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    margin-bottom: 1.25rem;
    background: rgba(139, 111, 71, 0.1);
    color: var(--color-accent, #8B6F47);
  }

  .event-feature--dark .event-feature__badge {
    background: rgba(198, 168, 108, 0.15);
    color: #C6A86C;
  }

  .event-feature__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.25rem;
  }

  .event-feature--dark .event-feature__title { color: #fff; }

  .event-feature__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0 0 1.25rem;
  }

  .event-feature--dark .event-feature__text { color: rgba(255,255,255,0.6); }

  .event-feature__detail {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.5rem;
  }

  .event-feature--dark .event-feature__detail { color: rgba(255,255,255,0.8); }

  .event-feature__awards {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: rgba(198, 168, 108, 0.08);
    border-radius: 0.75rem;
  }

  .event-feature__awards img {
    flex-shrink: 0;
  }

  .event-feature__awards div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
  }

  /* Events CTA */
  .events-cta {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    background: #F4F2EE;
    text-align: center;
  }

  .events-cta__inner { max-width: 500px; margin: 0 auto; }
  .events-cta__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 400; color: var(--color-text, #1A1A1A); margin: 0 0 1rem; }
  .events-cta__text { font-family: 'Inter', sans-serif; font-size: 1rem; color: var(--color-text-secondary, #6B6B6B); line-height: 1.7; margin: 0 0 1.5rem; }
  .events-cta__link { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: var(--color-accent, #8B6F47); text-decoration: none; transition: gap 0.3s; }
  .events-cta__link:hover { gap: 0.75rem; }

  @media (max-width: 768px) {
    .event-feature__container {
      grid-template-columns: 1fr;
    }
    .event-feature--reversed .event-feature__container {
      direction: ltr;
    }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
