---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Presentkort — GASTRO|nome Mat & Bar | Ge bort en upplevelse"
  description="Ge bort en oförglömlig matupplevelse. Köp presentkort till GASTRO|nome, Lunds #1 restaurang. Perfekt present till alla tillfällen."
>
  <!-- Mini hero banner for navbar visibility -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/652511994_18086431202349192_4627669848014543762_n.jpg" alt="Cocktail på GASTRO|nome uteservering" loading="eager" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="page-hero__content">
      <span class="page-hero__eyebrow">Presentkort</span>
      <h1 class="page-hero__title">Ge bort en upplevelse</h1>
    </div>
  </section>

  <section class="gift">
    <div class="gift__container">
      <div class="gift__content fade-up">
        <h2 class="gift__title">Perfekt present<br />till alla tillfällen</h2>
        <p class="gift__text">
          Letar du efter den perfekta presenten? Ett presentkort till GASTRO|nome ger mottagaren
          friheten att njuta av prisbelönt mat och dryck — när det passar dem bäst.
        </p>
        <p class="gift__text">
          Kontakta oss för att köpa presentkort till valfritt belopp. Vi skickar det digitalt eller
          så kan du hämta ett fysiskt kort hos oss.
        </p>

        <div class="gift__actions">
          <Button href="tel:046390000" variant="primary" size="lg">Ring Oss: 046-390000</Button>
          <Button href="mailto:info@gastronome.se" variant="outline" size="lg">Maila Oss</Button>
        </div>
      </div>

      <div class="gift__visual fade-up">
        <div class="gift__card">
          <div class="gift__card-inner">
            <span class="gift__card-logo">GASTRO<span class="gift__card-pipe">|</span>nome</span>
            <span class="gift__card-type">Presentkort</span>
            <div class="gift__card-bottom">
              <span class="gift__card-value">Valfritt belopp</span>
              <span class="gift__card-loc">Bangatan 6, Lund</span>
            </div>
          </div>
        </div>
        <img src="/images/654113767_18086540393349192_9128637126260060053_n.jpg" alt="Vintoast på GASTRO|nome" loading="lazy" class="gift__bg-image" />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

<style>
  /* Page Hero Banner */
  .page-hero { position: relative; height: 40vh; min-height: 280px; max-height: 400px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a; }
  .page-hero__bg { position: absolute; inset: 0; }
  .page-hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.25), rgba(0,0,0,0.6)); }
  .page-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .page-hero__eyebrow { display: block; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .page-hero__title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.25rem, 5vw, 4rem); font-weight: 400; color: #fff; margin: 0; }

  .gift {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .gift__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
    width: 100%;
  }

  .gift__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent, #8B6F47);
    margin-bottom: 1.25rem;
  }

  .gift__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1.5rem;
  }

  .gift__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0 0 1.25rem;
    max-width: 480px;
  }

  .gift__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .gift__visual {
    position: relative;
  }

  .gift__bg-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
  }

  .gift__card {
    position: absolute;
    bottom: -2rem;
    left: -1rem;
    width: 320px;
    z-index: 2;
  }

  .gift__card-inner {
    background: rgba(15, 15, 15, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 2rem;
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gift__card-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .gift__card-pipe { color: #C6A86C; }

  .gift__card-type {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .gift__card-bottom {
    margin-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .gift__card-value {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #C6A86C;
  }

  .gift__card-loc {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 768px) {
    .gift__container { grid-template-columns: 1fr; }
    .gift__card { position: relative; bottom: auto; left: auto; width: 100%; margin-top: -3rem; }
    .gift__actions { justify-content: center; }
    .gift__content { text-align: center; }
    .gift__text { margin-left: auto; margin-right: auto; }
  }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1); }
  .fade-up.is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .fade-up { opacity: 1; transform: none; transition: none; } }
</style>
