---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="404 — Sidan hittades inte" description="Sidan du söker finns inte." noindex={true}>
  <section class="not-found">
    <div class="not-found__content">
      <span class="not-found__code">404</span>
      <h1 class="not-found__title">Sidan hittades inte</h1>
      <p class="not-found__text">
        Sidan du letar efter verkar ha flyttats eller finns inte längre.
        Gå tillbaka till startsidan och utforska vår meny.
      </p>
      <div class="not-found__actions">
        <Button href="/" variant="primary" size="lg">Tillbaka till Hem</Button>
        <Button href="/menyer" variant="outline" size="lg">Se Menyn</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .not-found__content {
    max-width: 480px;
  }

  .not-found__code {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-border, #E8E5E0);
    margin-bottom: 1rem;
  }

  .not-found__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text, #1A1A1A);
    margin: 0 0 1rem;
  }

  .not-found__text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary, #6B6B6B);
    margin: 0 0 2rem;
  }

  .not-found__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
