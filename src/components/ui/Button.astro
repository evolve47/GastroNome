---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';

const classes = [
  'btn',
  `btn--${variant}`,
  `btn--${size}`,
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    transition:
      background-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-accent-warm, #8b6f47);
    outline-offset: 3px;
  }

  /* ── Sizes ── */
  .btn--sm {
    font-size: 0.6875rem;
    padding: 0.5rem 1.25rem;
    letter-spacing: 0.06em;
  }

  .btn--md {
    font-size: 0.8125rem;
    padding: 0.75rem 2rem;
  }

  .btn--lg {
    font-size: 0.875rem;
    padding: 1rem 2.75rem;
  }

  /* ── Primary: warm accent ── */
  .btn--primary {
    background-color: var(--color-accent-warm, #8b6f47);
    color: #ffffff;
  }

  .btn--primary:hover {
    background-color: #76593a;
    transform: scale(1.02);
    box-shadow: 0 4px 20px rgba(139, 111, 71, 0.3);
  }

  .btn--primary:active {
    transform: scale(0.97);
    box-shadow: none;
  }

  /* ── Secondary: dark ── */
  .btn--secondary {
    background-color: var(--color-text-primary, #1a1a1a);
    color: #ffffff;
  }

  .btn--secondary:hover {
    background-color: #333333;
    transform: scale(1.02);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .btn--secondary:active {
    transform: scale(0.97);
    box-shadow: none;
  }

  /* ── Outline: bordered ── */
  .btn--outline {
    background-color: transparent;
    color: rgba(255, 255, 255, 0.9);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }

  .btn--outline:hover {
    background-color: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.7);
    transform: scale(1.02);
  }

  .btn--outline:active {
    transform: scale(0.97);
  }

  /* Outline on light backgrounds (non-hero contexts) */
  :global(section:not(.hero)) .btn--outline {
    color: var(--color-accent-warm, #8b6f47);
    border-color: var(--color-accent-warm, #8b6f47);
  }

  :global(section:not(.hero)) .btn--outline:hover {
    background-color: var(--color-accent-warm, #8b6f47);
    color: #fff;
    border-color: var(--color-accent-warm, #8b6f47);
  }

  /* ── Ghost: transparent ── */
  .btn--ghost {
    background-color: transparent;
    color: currentColor;
    padding-inline: 0.75rem;
  }

  .btn--ghost:hover {
    background-color: rgba(0, 0, 0, 0.04);
  }

  .btn--ghost:active {
    transform: scale(0.97);
  }

  /* ── Dark section overrides ── */
  :global(.bg-dark) .btn--outline {
    color: var(--color-text-on-dark, #f5f5f4);
    border-color: var(--color-text-on-dark, #f5f5f4);
  }

  :global(.bg-dark) .btn--outline:hover {
    background-color: var(--color-text-on-dark, #f5f5f4);
    color: var(--color-bg-dark, #0f0f0f);
  }

  :global(.bg-dark) .btn--ghost {
    color: var(--color-text-on-dark, #f5f5f4);
  }

  :global(.bg-dark) .btn--ghost:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }
</style>
