---
interface Props {
  title: string;
  description: string;
  price?: string;
  image: string;
  href?: string;
  badge?: string;
  class?: string;
}

const {
  title,
  description,
  price,
  image,
  href,
  badge,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'div';
const wrapperClasses = [
  'event-card',
  'reveal',
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={wrapperClasses}>
    <div class="event-card__image-wrap">
      <img
        src={image}
        alt={title}
        class="event-card__image"
        loading="lazy"
        decoding="async"
      />
      <div class="event-card__overlay"></div>
    </div>

    {badge && (
      <span class="event-card__badge">{badge}</span>
    )}

    <div class="event-card__content">
      <h3 class="event-card__title">{title}</h3>
      <p class="event-card__description">{description}</p>
    </div>

    {price && (
      <span class="event-card__price">{price}</span>
    )}
  </a>
) : (
  <div class={wrapperClasses}>
    <div class="event-card__image-wrap">
      <img
        src={image}
        alt={title}
        class="event-card__image"
        loading="lazy"
        decoding="async"
      />
      <div class="event-card__overlay"></div>
    </div>

    {badge && (
      <span class="event-card__badge">{badge}</span>
    )}

    <div class="event-card__content">
      <h3 class="event-card__title">{title}</h3>
      <p class="event-card__description">{description}</p>
    </div>

    {price && (
      <span class="event-card__price">{price}</span>
    )}
  </div>
)}

<style>
  .event-card {
    position: relative;
    display: block;
    border-radius: var(--radius-2xl, 24px);
    overflow: hidden;
    text-decoration: none;
    color: #ffffff;
    aspect-ratio: 4 / 5;
    min-height: 380px;
    cursor: pointer;
  }

  /* ── Image ── */
  .event-card__image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .event-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .event-card:hover .event-card__image {
    transform: scale(1.05);
  }

  /* ── Gradient overlay ── */
  .event-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.78) 0%,
      rgba(0, 0, 0, 0.35) 40%,
      rgba(0, 0, 0, 0.08) 70%,
      transparent 100%
    );
    z-index: 1;
    transition: background 0.4s ease;
  }

  .event-card:hover .event-card__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.45) 45%,
      rgba(0, 0, 0, 0.12) 70%,
      transparent 100%
    );
  }

  /* ── Badge (frosted glass) ── */
  .event-card__badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.375rem 1rem;
    border-radius: 9999px;
  }

  /* ── Content ── */
  .event-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: clamp(1.5rem, 3vw, 2rem);
    padding-bottom: clamp(1.5rem, 3vw, 2rem);
  }

  .event-card__title {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    line-height: 1.15;
    color: #ffffff;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .event-card__description {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    max-height: 2.5em;
    overflow: hidden;
    transition:
      max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s ease;
  }

  .event-card:hover .event-card__description {
    max-height: 8em;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ── Price tag ── */
  .event-card__price {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #ffffff;
    background: rgba(139, 111, 71, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.375rem 1rem;
    border-radius: 9999px;
  }

  /* ── Focus for accessible keyboard nav ── */
  a.event-card:focus-visible {
    outline: 2px solid var(--color-accent-warm, #8b6f47);
    outline-offset: 4px;
    border-radius: var(--radius-2xl, 24px);
  }

  /* ── Responsive ── */
  @media (min-width: 768px) {
    .event-card {
      aspect-ratio: 3 / 4;
      min-height: 420px;
    }
  }

  @media (min-width: 1024px) {
    .event-card {
      min-height: 480px;
    }
  }
</style>
