---
import { siteConfig } from '@data/site';
import { t, getNav } from '../../i18n/utils';
import type { Locale } from '../../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'sv' } = Astro.props;

const currentYear = new Date().getFullYear();
const navItems = getNav(lang);

/* Translated day names */
const dayKeys = [
  'hours.monday',
  'hours.tuesday',
  'hours.wednesday',
  'hours.thursday',
  'hours.friday',
  'hours.saturday',
  'hours.sunday',
] as const;

const hoursData = siteConfig.hours.map((h, i) => ({
  day: t(lang, dayKeys[i]),
  hours: h.hours === 'Stängt' ? t(lang, 'hours.closed') : h.hours,
  isClosed: h.hours === 'Stängt',
}));
---

<footer class="footer" role="contentinfo">
  <!-- Decorative top border -->
  <div class="footer__border"></div>

  <!-- Pull-quote -->
  <div class="footer__quote-section">
    <div class="footer__container">
      <p class="footer__quote reveal">
        &ldquo;{t(lang, 'footer.quote')}&rdquo;
      </p>
    </div>
  </div>

  <!-- Main grid -->
  <div class="footer__main">
    <div class="footer__container footer__grid">
      <!-- Col 1: Contact -->
      <div class="footer__col reveal">
        <h3 class="footer__col-title">{t(lang, 'footer.visitUs')}</h3>
        <address class="footer__address">
          <a href="https://maps.google.com/?q=Bangatan+6,+222+21+Lund,+Sweden" target="_blank" rel="noopener noreferrer" class="footer__address-link">
            <p>{siteConfig.address.street}</p>
            <p>{siteConfig.address.zip} {siteConfig.address.city}</p>
          </a>
        </address>
        <div class="footer__contact-links">
          <a
            href="tel:+46-46-390000"
            class="footer__link"
          >
            {siteConfig.phone}
          </a>
          <a href={`mailto:${siteConfig.email}`} class="footer__link">
            {siteConfig.email}
          </a>
        </div>
      </div>

      <!-- Col 2: Opening hours -->
      <div class="footer__col reveal">
        <h3 class="footer__col-title">{t(lang, 'footer.openingHours')}</h3>
        <table class="footer__hours" role="presentation">
          <tbody>
            {hoursData.map((h) => (
              <tr class:list={[{ 'is-closed': h.isClosed }]}>
                <td class="footer__hours-day">{h.day}</td>
                <td class="footer__hours-time">{h.hours}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Col 3: Navigation + Social -->
      <div class="footer__col reveal">
        <h3 class="footer__col-title">{t(lang, 'footer.navigation')}</h3>
        <ul class="footer__nav-links">
          {navItems.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>

        <h3 class="footer__col-title footer__col-title--social">{t(lang, 'footer.followUs')}</h3>
        <div class="footer__social">
          <!-- Facebook -->
          <a
            href={siteConfig.social.facebook}
            class="footer__social-link"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href={siteConfig.social.instagram}
            class="footer__social-link"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect
                x="2" y="2" width="20" height="20" rx="5"
                stroke="currentColor" stroke-width="1.5"
              />
              <circle
                cx="12" cy="12" r="5"
                stroke="currentColor" stroke-width="1.5"
              />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
            </svg>
          </a>

          <!-- TripAdvisor -->
          <a
            href={siteConfig.social.tripadvisor}
            class="footer__social-link"
            aria-label="TripAdvisor"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="7.5" cy="14" r="3" stroke="currentColor" stroke-width="1.5" />
              <circle cx="16.5" cy="14" r="3" stroke="currentColor" stroke-width="1.5" />
              <path
                d="M4.5 14a7.5 7.5 0 0 1 15 0"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
              <path
                d="M12 4c-2.5 0-4.8.7-6.6 2M12 4c2.5 0 4.8.7 6.6 2"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
              <circle cx="7.5" cy="14" r="1" fill="currentColor" />
              <circle cx="16.5" cy="14" r="1" fill="currentColor" />
              <path d="M12 7v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="footer__container footer__bottom-inner">
      <p class="footer__copyright">
        &copy; {currentYear} Gastronome. {t(lang, 'footer.copyright')}
      </p>
      <p class="footer__credit">
        {t(lang, 'footer.credit')}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark, #0f0f0f);
    color: var(--color-text-on-dark, #f5f5f4);
    position: relative;
  }

  .footer__border {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(139, 111, 71, 0.4) 30%,
      rgba(139, 111, 71, 0.4) 70%,
      transparent 100%
    );
  }

  .footer__container {
    width: 100%;
    max-width: var(--container-max, 1400px);
    margin-inline: auto;
    padding-inline: var(--container-padding, clamp(1.25rem, 4vi, 3rem));
  }

  /* ── Quote ── */
  .footer__quote-section {
    padding-block: clamp(3rem, 6vw, 5rem);
    text-align: center;
  }

  .footer__quote {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text-on-dark, #f5f5f4);
    letter-spacing: -0.01em;
    line-height: 1.2;
    opacity: 0.85;
  }

  /* ── Main grid ── */
  .footer__main {
    padding-bottom: clamp(3rem, 6vw, 4rem);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 4vw, 3rem);
  }

  .footer__col-title {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-warm-light, #a68b63);
    margin-bottom: 1.25rem;
  }

  .footer__col-title--social {
    margin-top: 2rem;
  }

  /* ── Address ── */
  .footer__address {
    font-style: normal;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-on-dark-secondary, #a8a8a8);
    margin-bottom: 1rem;
  }

  .footer__address-link {
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .footer__address-link:hover {
    color: var(--color-text-on-dark, #f5f5f4);
  }

  .footer__contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer__link {
    position: relative;
    display: inline-block;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.9375rem;
    color: var(--color-text-on-dark-secondary, #a8a8a8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer__link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent-warm, #8b6f47);
    transition: width 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__link:hover {
    color: var(--color-text-on-dark, #f5f5f4);
  }

  .footer__link:hover::after {
    width: 100%;
  }

  /* ── Hours table ── */
  .footer__hours {
    width: 100%;
    border-collapse: collapse;
  }

  .footer__hours tr {
    border: none;
  }

  .footer__hours td {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.9375rem;
    padding-block: 0.35rem;
    color: var(--color-text-on-dark-secondary, #a8a8a8);
  }

  .footer__hours-day {
    padding-right: 2rem;
    white-space: nowrap;
  }

  .footer__hours-time {
    text-align: right;
    white-space: nowrap;
  }

  .footer__hours tr.is-closed td {
    color: var(--color-text-tertiary, #9a9a9a);
    opacity: 0.5;
  }

  /* ── Nav links ── */
  .footer__nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ── Social ── */
  .footer__social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border-dark, #2a2a2a);
    color: var(--color-text-on-dark-secondary, #a8a8a8);
    text-decoration: none;
    transition:
      color 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .footer__social-link:hover {
    color: var(--color-text-on-dark, #f5f5f4);
    border-color: var(--color-accent-warm, #8b6f47);
    background-color: rgba(139, 111, 71, 0.12);
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    border-top: 1px solid var(--color-border-dark, #2a2a2a);
    padding-block: 1.5rem;
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    text-align: center;
  }

  .footer__copyright,
  .footer__credit {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.75rem;
    color: var(--color-text-tertiary, #9a9a9a);
    letter-spacing: 0.03em;
  }

  .footer__credit {
    opacity: 0.6;
  }

  /* ── Responsive: tablet+ ── */
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: clamp(2rem, 4vw, 4rem);
    }

    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
