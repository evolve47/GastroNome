---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  dark?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = 'center',
  dark = false,
  class: className = '',
} = Astro.props;

const wrapperClasses = [
  'section-heading',
  `section-heading--${align}`,
  dark ? 'section-heading--dark' : '',
  'reveal',
  className,
].filter(Boolean).join(' ');
---

<div class={wrapperClasses}>
  {eyebrow && (
    <div class="section-heading__eyebrow-wrap">
      <span class="section-heading__eyebrow">{eyebrow}</span>
    </div>
  )}
  <h2 class="section-heading__title">{title}</h2>
  {subtitle && (
    <p class="section-heading__subtitle">{subtitle}</p>
  )}
</div>

<style>
  .section-heading {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  /* ── Alignment ── */
  .section-heading--center {
    text-align: center;
  }

  .section-heading--center .section-heading__subtitle {
    margin-inline: auto;
  }

  .section-heading--center .section-heading__eyebrow-wrap {
    justify-content: center;
  }

  .section-heading--left {
    text-align: left;
  }

  /* ── Eyebrow ── */
  .section-heading__eyebrow-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-heading__eyebrow {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-warm, #8b6f47);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-heading__eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1.5px;
    background-color: var(--color-accent-warm, #8b6f47);
    flex-shrink: 0;
  }

  /* ── Title ── */
  .section-heading__title {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-text-primary, #1a1a1a);
    margin-bottom: 0;
  }

  /* ── Subtitle ── */
  .section-heading__subtitle {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: var(--text-base, 1rem);
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-secondary, #6b6b6b);
    max-width: 600px;
    margin-top: 1rem;
  }

  /* ── Dark variant ── */
  .section-heading--dark .section-heading__title {
    color: var(--color-text-on-dark, #f5f5f4);
  }

  .section-heading--dark .section-heading__subtitle {
    color: var(--color-text-on-dark-secondary, #a8a8a8);
  }

  .section-heading--dark .section-heading__eyebrow {
    color: var(--color-accent-warm-light, #a68b63);
  }

  .section-heading--dark .section-heading__eyebrow::before {
    background-color: var(--color-accent-warm-light, #a68b63);
  }
</style>
