---
import type { Locale } from '../../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'sv' } = Astro.props;

const menuHref = lang === 'en' ? '/en/menus/' : '/menyer/';
---

<section class="showcase">
  <div class="showcase__header fade-up">
    <span class="showcase__eyebrow">Från Vårt Kök</span>
    <h2 class="showcase__title">Smakupplevelser utöver det vanliga</h2>
  </div>

  <div class="showcase__grid">
    <!-- Row 1: Large left + 2 stacked right -->
    <a href={menuHref} class="showcase__item showcase__item--feature fade-up" aria-label="Insalata Caprese">
      <img src="/images/caprese-burrata.webp" alt="Insalata Caprese med burrata, färska tomater och basilika" loading="lazy" decoding="async" width="2880" height="1920" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Insalata Caprese</span>
      </div>
    </a>

    <a href={menuHref} class="showcase__item fade-up delay-1" aria-label="Pizza Margherita">
      <img src="/images/fc037b4ad21057456dde5a40cd6d09f2-thumb_large.webp" alt="Neapolitansk margherita med färsk basilika" loading="lazy" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Pizza Margherita</span>
      </div>
    </a>

    <a href={menuHref} class="showcase__item fade-up delay-2" aria-label="Polpo alla Griglia">
      <img src="/images/polpo-alla-griglia-grilled.webp" alt="Grillad bläckfisk med tomater och örter" loading="lazy" decoding="async" width="600" height="400" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Polpo alla Griglia</span>
      </div>
    </a>

    <!-- Row 2: 3 equal columns -->
    <a href={menuHref} class="showcase__item fade-up" aria-label="Pizza & Vin">
      <img src="/images/unnamed.webp" alt="Gourmetpizza med prosciutto och vin i restaurangmiljö" loading="lazy" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Pizza & Vin</span>
      </div>
    </a>

    <a href={menuHref} class="showcase__item fade-up delay-1" aria-label="Craft Cocktails">
      <img src="/images/640032801_18084581579349192_488592742248204250_n.webp" alt="Elegant rosa cocktail i coupeglas" loading="lazy" decoding="async" width="600" height="400" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Craft Cocktails</span>
      </div>
    </a>

    <a href={menuHref} class="showcase__item fade-up delay-2" aria-label="Pane Grigliato">
      <img src="/images/649490008_18085290014349192_920750879952780296_n.webp" alt="Grillat bröd med olivolja" loading="lazy" decoding="async" width="600" height="400" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Pane Grigliato</span>
      </div>
    </a>

    <!-- Row 3: 2 new images to fill the grid -->
    <a href={menuHref} class="showcase__item fade-up" aria-label="Antipasti">
      <img src="/images/640820505_18084012917349192_4427101478650068827_n.webp" alt="Italiensk antipasti med chark, ost och oliver" loading="lazy" decoding="async" width="600" height="400" />
      <div class="showcase__overlay">
        <span class="showcase__dish">Antipasti</span>
      </div>
    </a>

    <a href={menuHref} class="showcase__item showcase__item--wide fade-up delay-1" aria-label="Middagsuppdukning">
      <img src="/images/dinner-spread-wide.webp" alt="Fulldukat bord med pizza, pasta, oliver och italienska rätter" loading="lazy" decoding="async" width="1600" height="800" />
      <div class="showcase__overlay">
        <span class="showcase__dish">La Tavola — Middagsupplevelsen</span>
      </div>
    </a>
  </div>

  <div class="showcase__cta fade-up">
    <a href={menuHref} class="showcase__link">
      {lang === 'en' ? 'See the full menu' : 'Se hela menyn'}
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>

<style>
  .showcase {
    padding: clamp(5rem, 10vw, 8rem) 1.5rem;
    background: var(--color-bg, #FAFAF9);
  }

  .showcase__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .showcase__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent, #8B6F47);
    margin-bottom: 1rem;
  }

  .showcase__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text, #1A1A1A);
    margin: 0;
  }

  /* === Grid: 3 columns, asymmetric rows === */
  .showcase__grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 320px 280px 260px;
    gap: 0.75rem;
  }

  /* Feature item spans 2 rows on first column */
  .showcase__item--feature {
    grid-row: 1 / 2;
    grid-column: 1 / 2;
  }

  /* Wide item spans 2 columns */
  .showcase__item--wide {
    grid-column: span 2;
  }

  .showcase__item {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .showcase__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .showcase__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.55) 100%);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .showcase__dish {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.02em;
    backdrop-filter: blur(4px);
    background: rgba(255, 255, 255, 0.12);
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
  }

  .showcase__item:hover img {
    transform: scale(1.05);
  }

  .showcase__item:hover .showcase__overlay {
    opacity: 1;
  }

  .showcase__cta {
    text-align: center;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .showcase__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent, #8B6F47);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .showcase__link:hover {
    gap: 0.875rem;
  }

  @media (max-width: 900px) {
    .showcase__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(4, 240px);
    }

    .showcase__item--feature {
      grid-row: auto;
      grid-column: auto;
    }

    .showcase__item--wide {
      grid-column: span 2;
    }

    .showcase__overlay {
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .showcase__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .showcase__item--wide {
      grid-column: span 1;
    }

    .showcase__item img {
      aspect-ratio: 4 / 3;
    }
  }
</style>
