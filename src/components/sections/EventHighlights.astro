---
import type { Locale } from '../../i18n/ui';
import { t } from '../../i18n/utils';

interface Props {
  lang?: Locale;
}

const { lang = 'sv' } = Astro.props;

const eventsHref = lang === 'en' ? '/en/events/' : '/evenemang/';
const menuHref = lang === 'en' ? '/en/menus/' : '/menyer/';
const groupsHref = lang === 'en' ? '/en/large-groups/' : '/stora-sallskap/';
---

<section class="events" id="evenemang">
  <div class="events__container">
    <div class="events__header fade-up">
      <span class="events__eyebrow">{t(lang, 'eventsHome.eyebrow')}</span>
      <h2 class="events__title">{t(lang, 'eventsHome.title')}</h2>
    </div>

    <div class="events__grid">
      <a href={eventsHref} class="event-card fade-up">
        <div class="event-card__image">
          <img
            src="/images/619226756_18080282837349192_8699460402074805794_n.webp"
            alt="Champagne hälls i glas — Bubbeltorsdag på GASTRO|nome"
            loading="lazy"
            decoding="async"
            width="600"
            height="450"
          />
          <div class="event-card__gradient"></div>
          <span class="event-card__badge">{t(lang, 'eventsHome.bubbleBadge')}</span>
        </div>
        <div class="event-card__content">
          <h3 class="event-card__title">{t(lang, 'eventsHome.bubbleTitle')}</h3>
          <p class="event-card__desc">{t(lang, 'eventsHome.bubbleDesc')}</p>
        </div>
      </a>

      <a href={menuHref} class="event-card fade-up delay-1">
        <div class="event-card__image">
          <img
            src="/images/fc037b4ad21057456dde5a40cd6d09f2-thumb_large.webp"
            alt="SM-vinnande pizza — Vinnare Pizza SM 2023 och 2024"
            loading="lazy"
            decoding="async"
            width="600"
            height="450"
          />
          <div class="event-card__gradient"></div>
          <span class="event-card__badge">{t(lang, 'eventsHome.pizzaBadge')}</span>
        </div>
        <div class="event-card__content">
          <h3 class="event-card__title">{t(lang, 'eventsHome.pizzaTitle')}</h3>
          <p class="event-card__desc">{t(lang, 'eventsHome.pizzaDesc')}</p>
        </div>
      </a>

      <a href={groupsHref} class="event-card fade-up delay-2">
        <div class="event-card__image">
          <img
            src="/images/467249171_18037063073349192_5208946929036331443_n.webp"
            alt="Stort middagssällskap med dukat bord — Stora Sällskap"
            loading="lazy"
            decoding="async"
            width="600"
            height="450"
          />
          <div class="event-card__gradient"></div>
          <span class="event-card__badge">{t(lang, 'eventsHome.groupBadge')}</span>
        </div>
        <div class="event-card__content">
          <h3 class="event-card__title">{t(lang, 'eventsHome.groupTitle')}</h3>
          <p class="event-card__desc">{t(lang, 'eventsHome.groupDesc')}</p>
        </div>
      </a>
    </div>

    <div class="events__cta fade-up">
      <a href={eventsHref} class="events__link">
        {t(lang, 'eventsHome.cta')}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .events {
    background: var(--color-bg-dark, #0F0F0F);
    padding: clamp(5rem, 10vw, 8rem) 1.5rem;
  }

  .events__container {
    max-width: 1300px;
    margin: 0 auto;
  }

  .events__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .events__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C6A86C;
    margin-bottom: 1rem;
  }

  .events__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 1.15;
    color: #fff;
    margin: 0;
  }

  .events__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .event-card {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    background: #1A1A1A;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
  }

  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
  }

  .event-card__image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .event-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .event-card:hover .event-card__image img {
    transform: scale(1.06);
  }

  .event-card__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.4) 100%);
  }

  .event-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .event-card__content {
    padding: 1.5rem;
  }

  .event-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .event-card__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .events__cta {
    text-align: center;
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .events__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #C6A86C;
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .events__link:hover {
    gap: 0.875rem;
  }

  @media (max-width: 900px) {
    .events__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
